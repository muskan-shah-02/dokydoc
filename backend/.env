# DokyDoc Environment Configuration for Docker

# Environment & Deployment
ENVIRONMENT=development
DEBUG=true
API_VERSION=v1

# Project Settings
PROJECT_NAME=DokyDoc
PROJECT_VERSION=1.0.0

# Server Settings
HOST=0.0.0.0
PORT=8000
WORKERS=1

# Database Settings
DATABASE_URL=postgresql://postgres:simplepass@db:5432/dokydoc
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30
DATABASE_POOL_TIMEOUT=30

# Security Settings
SECRET_KEY=your-super-secret-key-here-make-it-at-least-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Settings
CORS_ORIGINS='["http://localhost:3000", "http://localhost:8000"]'
CORS_ALLOW_CREDENTIALS=true

# AI Service Settings
GEMINI_API_KEY=AIzaSyAJex1xQHisP3T3zkJLnErQBRAzCunD79I
GEMINI_MODEL=gemini-2.5-flash
GEMINI_VISION_MODEL=gemini-2.5-flash
GEMINI_MAX_RETRIES=3
GEMINI_TIMEOUT=60

# File Upload Settings
MAX_FILE_SIZE=52428800
UPLOAD_DIR=/app/uploads
ALLOWED_EXTENSIONS='[".pdf", ".docx", ".doc", ".txt"]'

# Cache Settings
REDIS_URL=redis://redis:6379
CACHE_TTL=3600

# Logging Settings
LOG_LEVEL=INFO
LOG_FORMAT=json

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000

# Background Task Settings
MAX_WORKERS=4
TASK_TIMEOUT=300

# Celery Settings
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_RESULT_BACKEND_URL=redis://redis:6379/1
CELERY_TASK_TRACK_STARTED=true
CELERY_TASK_TIME_LIMIT=1800
CELERY_TASK_SOFT_TIME_LIMIT=1500