################################################################################
# DokydDoc — Production Environment Variables
# Copy to .env on your server: cp .env.production.example .env
# Then fill in ALL values marked REQUIRED
################################################################################

# ── Environment ──────────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
API_VERSION=v1
PROJECT_NAME=DokyDoc
PROJECT_VERSION=1.0.0

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=4                              # Match Gunicorn --workers in docker-compose.prod.yml

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# REQUIRED: Set a strong password — never use defaults in production
POSTGRES_USER=dokydoc
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
POSTGRES_DB=dokydoc
DATABASE_URL=postgresql://dokydoc:CHANGE_ME_STRONG_PASSWORD_HERE@db:5432/dokydoc

# Connection pooling — tune based on your server RAM
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30
DATABASE_POOL_TIMEOUT=30

# ── Redis ─────────────────────────────────────────────────────────────────────
# REQUIRED: Set a Redis password
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_HERE
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD_HERE@redis:6379/0
CELERY_BROKER_URL=redis://:CHANGE_ME_REDIS_PASSWORD_HERE@redis:6379/1
CELERY_RESULT_BACKEND=redis://:CHANGE_ME_REDIS_PASSWORD_HERE@redis:6379/2
CACHE_TTL=3600

# ── Security ─────────────────────────────────────────────────────────────────
# REQUIRED: Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── CORS ──────────────────────────────────────────────────────────────────────
# REQUIRED: Set to your actual frontend domain
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,https://yourdomain.vercel.app
CORS_ALLOW_CREDENTIALS=true

# ── AI Services ───────────────────────────────────────────────────────────────
# REQUIRED: Get from https://aistudio.google.com/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-1.5-pro-latest
GEMINI_VISION_MODEL=gemini-1.5-pro-latest
GEMINI_MAX_RETRIES=3
GEMINI_TIMEOUT=90                      # Longer timeout for large repos

# ── File Uploads ──────────────────────────────────────────────────────────────
MAX_FILE_SIZE=52428800                 # 50MB
UPLOAD_DIR=/app/uploads
ALLOWED_EXTENSIONS=.pdf,.docx,.doc,.txt

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=500

# ── Background Tasks ─────────────────────────────────────────────────────────
MAX_WORKERS=4
TASK_TIMEOUT=300

# ── GitHub Integration (for repository scanning) ──────────────────────────────
# Optional: Increases GitHub API rate limit from 60/hour to 5000/hour
GITHUB_TOKEN=ghp_YOUR_GITHUB_TOKEN_HERE

# ── Flower (Celery monitor) ──────────────────────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=CHANGE_ME_FLOWER_PASSWORD_HERE

# ── Monitoring / Error Tracking (optional but recommended) ───────────────────
# Sentry: Get DSN from https://sentry.io (free tier available)
# SENTRY_DSN=https://xxx@o000.ingest.sentry.io/000

# ── Email / Notifications (optional) ─────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASSWORD=your-app-password
